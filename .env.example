# homelab-observability Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to git - it contains sensitive data

# ============================================================================
# HOST CONFIGURATION
# ============================================================================
HOST_IP=192.168.1.100
HOSTNAME=labhost00
TIMEZONE=America/New_York

# ============================================================================
# NETWORKING
# ============================================================================
DOCKER_NETWORK=observability_network
SUBNET=172.20.0.0/16

# ============================================================================
# PHASE I: FOUNDATION
# ============================================================================

# Portainer
PORTAINER_PORT=9443
PORTAINER_AGENT_PORT=8001

# Uptime Kuma
UPTIME_KUMA_PORT=3001

# ============================================================================
# PHASE II: METRICS HUB
# ============================================================================

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# Alertmanager
ALERTMANAGER_PORT=9093

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ============================================================================
# PHASE III: INFRASTRUCTURE MONITORING
# ============================================================================

# Checkmk
CHECKMK_SITE_PORT=5000
CHECKMK_AGENT_PORT=8000

# Nagios
NAGIOS_PORT=8081

# ============================================================================
# PHASE IV: HEAVY HITTERS
# ============================================================================

# Docker-ELK Stack
KIBANA_PORT=5601
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_MEM=2g
ELASTIC_PASSWORD=changeme

# Graylog
GRAYLOG_PORT=9002
GRAYLOG_SYSLOG_PORT=1514
GRAYLOG_BEATS_PORT=5045
GRAYLOG_PASSWORD_SECRET=changeme_at_least_16_chars
GRAYLOG_ROOT_PASSWORD_SHA2=changeme_hash
MONGODB_USER=graylog
MONGODB_PASSWORD=changeme

# Wazuh
WAZUH_DASHBOARD_PORT=8443
WAZUH_SYSLOG_PORT=1515
WAZUH_API_PORT=55000

# ============================================================================
# DATA PERSISTENCE PATHS (Adjust for your system)
# ============================================================================
DATA_ROOT=/share/Container/observability
# Or for standard Linux: /opt/observability

# ============================================================================
# ALERT NOTIFICATION (Optional)
# ============================================================================
ALERT_EMAIL=alerts@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# ============================================================================
# STREAM-LAKE INTEGRATION
# ============================================================================
STREAM_LAKE_HOST=192.168.1.101
KAFKA_BOOTSTRAP_SERVERS=192.168.1.101:9092
